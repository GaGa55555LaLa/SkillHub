# Postgres 連線字串（Neon / Supabase / 本地 npx prisma dev）
DATABASE_URL="postgresql://user:password@localhost:5432/skillhub"

# Auth.js（npx auth secret 產生）
AUTH_SECRET=""

# GitHub OAuth App（登入用，DESIGN.md §2.1「認人」；任何 GitHub 帳號皆可登入）
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# GitHub App（讀資料用，DESIGN.md §2.1「取資料」）
# 「Where can this GitHub App be installed?」必須設為 Any account
# Setup URL 要填 <host>/api/github/setup
GITHUB_APP_ID=""
GITHUB_APP_PRIVATE_KEY=""          # PEM 內容，換行以 \n 表示
GITHUB_WEBHOOK_SECRET=""

# Admin GitHub login，逗號分隔（可觸發手動全量刷新 /api/admin/sync）
ADMIN_LOGINS=""

# 排程 sync（/api/cron/sync）的驗證密鑰。部署在 Vercel 時設定同名的
# 環境變數，Vercel Cron 呼叫時會自動帶 `Authorization: Bearer $CRON_SECRET`。
# 產生方式：openssl rand -hex 32
CRON_SECRET=""
