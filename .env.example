# Postgres 連線字串（Neon / Supabase / 本地 npx prisma dev）
DATABASE_URL="postgresql://user:password@localhost:5432/skillhub"

# Auth.js（npx auth secret 產生）
AUTH_SECRET=""

# GitHub OAuth App（登入用，DESIGN.md §2.1「認人」）
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# 團隊的 GitHub Organization 名稱（登入閘門）
GITHUB_ORG=""

# GitHub App（讀資料用，DESIGN.md §2.1「取資料」）
GITHUB_APP_ID=""
GITHUB_APP_PRIVATE_KEY=""          # PEM 內容，換行以 \n 表示
GITHUB_ORG_INSTALLATION_ID=""      # App 安裝在 org 上的 installation id
GITHUB_WEBHOOK_SECRET=""

# Admin GitHub login，逗號分隔（可觸發手動刷新）
ADMIN_LOGINS=""
