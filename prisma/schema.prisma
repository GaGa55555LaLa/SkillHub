generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ShareMode {
  whole_repo
  selected_only
}

enum RepoVisibility {
  public
  private
}

enum AuditAction {
  view
  download
}

model User {
  id              String   @id @default(cuid())
  githubId        BigInt   @unique @map("github_id")
  githubLogin     String   @unique @map("github_login")
  githubAvatarUrl String?  @map("github_avatar_url")
  createdAt       DateTime @default(now()) @map("created_at")

  ownedSources     SkillSource[]    @relation("SourceOwner")
  apiTokens        ApiToken[]
  auditLogs        AccessAuditLog[]
  grantedShares    SkillShare[]     @relation("ShareGrantedBy")
  receivedShares   SkillShare[]     @relation("ShareGranteeUser")
  ownedGroups      Group[]          @relation("GroupOwner")
  groupMemberships GroupMember[]

  @@map("users")
}

model SkillSource {
  id             String         @id @default(cuid())
  repoFullName   String         @unique @map("repo_full_name")
  ownerUserId    String         @map("owner_user_id")
  installationId BigInt         @map("installation_id")
  shareMode      ShareMode      @default(selected_only) @map("share_mode")
  visibility     RepoVisibility @default(private)
  isPublic       Boolean        @default(false) @map("is_public")
  lastSyncedAt   DateTime?      @map("last_synced_at")
  lastCommitSha  String?        @map("last_commit_sha")
  createdAt      DateTime       @default(now()) @map("created_at")

  owner  User         @relation("SourceOwner", fields: [ownerUserId], references: [id])
  skills Skill[]
  shares SkillShare[]

  @@map("skill_sources")
}

model Skill {
  id          String   @id @default(cuid())
  sourceId    String   @map("source_id")
  path        String
  name        String
  description String?
  contentSha  String?  @map("content_sha")
  isPublished Boolean  @default(true) @map("is_published")
  isPublic    Boolean  @default(false) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  source       SkillSource         @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  contentCache SkillContentCache[]
  shares       SkillShare[]
  auditLogs    AccessAuditLog[]

  @@unique([sourceId, path])
  @@map("skills")
}

model SkillContentCache {
  id          String   @id @default(cuid())
  skillId     String   @map("skill_id")
  filePath    String   @map("file_path")
  fileContent String   @map("file_content")
  cachedAt    DateTime @default(now()) @map("cached_at")

  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([skillId, filePath])
  @@map("skill_content_cache")
}

model Group {
  id          String   @id @default(cuid())
  name        String
  ownerUserId String   @map("owner_user_id")
  createdAt   DateTime @default(now()) @map("created_at")

  owner   User          @relation("GroupOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  members GroupMember[]
  shares  SkillShare[]

  @@unique([ownerUserId, name])
  @@map("groups")
}

model GroupMember {
  id      String   @id @default(cuid())
  groupId String   @map("group_id")
  userId  String   @map("user_id")
  addedAt DateTime @default(now()) @map("added_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
}

model SkillShare {
  id             String   @id @default(cuid())
  skillId        String?  @map("skill_id")
  sourceId       String   @map("source_id")
  granteeUserId  String?  @map("grantee_user_id")
  granteeGroupId String?  @map("grantee_group_id")
  grantedById    String   @map("granted_by")
  grantedAt      DateTime @default(now()) @map("granted_at")

  skill        Skill?      @relation(fields: [skillId], references: [id], onDelete: Cascade)
  source       SkillSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  granteeUser  User?       @relation("ShareGranteeUser", fields: [granteeUserId], references: [id], onDelete: Cascade)
  granteeGroup Group?      @relation(fields: [granteeGroupId], references: [id], onDelete: Cascade)
  grantedBy    User        @relation("ShareGrantedBy", fields: [grantedById], references: [id])

  @@map("skill_shares")
}

model ApiToken {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash")
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")
  revokedAt  DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_tokens")
}

model AccessAuditLog {
  id          String      @id @default(cuid())
  actorUserId String      @map("actor_user_id")
  skillId     String      @map("skill_id")
  action      AuditAction
  accessedAt  DateTime    @default(now()) @map("accessed_at")

  actor User  @relation(fields: [actorUserId], references: [id])
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@map("access_audit_log")
}
